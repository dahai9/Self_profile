---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="site-title"><a href="/Self_profile/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/Self_profile/">Home</HeaderLink>
			<HeaderLink href="/Self_profile/blog">Blog</HeaderLink>
			<HeaderLink href="/Self_profile/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/dahai9" target="_blank">
				<span class="sr-only">Go to GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--gray-light);
    position: sticky;
    top: 0;
    z-index: 10;
	}

  @media (prefers-color-scheme: dark) {
    header {
      background: rgba(15, 23, 42, 0.8);
      border-bottom-color: rgba(51, 65, 85, 0.5);
    }
  }

	.site-title {
		margin: 0;
		font-size: 1.2rem;
    font-weight: 800;
	}

	.site-title a {
		text-decoration: none;
    color: var(--black);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
    max-width: 1000px;
    margin: 0 auto;
    height: 4rem;
	}

	.internal-links {
    display: flex;
    gap: 0.5rem;
	}

	nav a {
		padding: 0.5rem 0.75rem;
		color: var(--gray);
		text-decoration: none;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s ease;
	}

	nav a:hover {
		background-color: var(--gray-light);
    color: var(--black);
	}

	nav a.active {
		color: var(--accent);
    background-color: var(--accent-light);
	}

  @media (prefers-color-scheme: dark) {
    nav a.active {
      background-color: rgba(99, 102, 241, 0.2);
      color: #a5b4fc;
    }
    nav a:hover {
      background-color: rgba(51, 65, 85, 0.5);
      color: #f1f5f9;
    }
  }

	.social-links {
		display: flex;
    gap: 0.5rem;
	}

  .social-links a {
    color: var(--gray);
    display: flex;
    align-items: center;
    padding: 0.5rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .social-links a:hover {
    color: var(--black);
    background-color: var(--gray-light);
  }

  @media (prefers-color-scheme: dark) {
    .social-links a:hover {
      background-color: rgba(51, 65, 85, 0.5);
      color: #f1f5f9;
    }
  }

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
    .internal-links {
      gap: 0;
    }
	}
</style>
