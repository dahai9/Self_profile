---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        margin: 4rem 0;
      }
      .hero h1 {
        font-size: 3.5rem;
        margin: 0;
        letter-spacing: -0.05em;
      }
      .hero p {
        font-size: 1.5rem;
        color: var(--gray);
        margin-top: 1rem;
        line-height: 1.4;
      }
      .section-title {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--gray);
        margin: 4rem 0 2rem;
        border-bottom: 1px solid var(--gray-light);
        padding-bottom: 0.5rem;
      }
      .recent-posts {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-entry {
        margin-bottom: 2rem;
      }
      .post-entry a {
        text-decoration: none;
        display: block;
      }
      .post-entry .date {
        font-size: 0.9rem;
        color: var(--gray);
        font-family: ui-monospace, SFMono-Regular, monospace;
      }
      .post-entry .title {
        font-size: 1.5rem;
        margin: 0.25rem 0;
        color: var(--black);
        font-weight: 700;
      }
      .post-entry a:hover .title {
        color: var(--accent);
      }
      .view-all {
        display: inline-block;
        margin-top: 2rem;
        font-weight: 600;
        color: var(--accent);
      }
      @media (max-width: 720px) {
        .hero h1 { font-size: 2.5rem; }
        .hero p { font-size: 1.25rem; }
      }
    </style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Share Ideas. <br/> Discuss Tech.</h1>
				<p>
					Welcome to my space for technical deep dives, creative thoughts, and everything in between.
				</p>
			</section>

      <h2 class="section-title">Recent Writing</h2>
      <ul class="recent-posts">
        {posts.map(post => (
          <li class="post-entry">
            <a href={`/Self_profile/blog/${post.id}/`}>
              <div class="date"><FormattedDate date={post.data.pubDate} /></div>
              <h3 class="title">{post.data.title}</h3>
            </a>
          </li>
        ))}
      </ul>
      <a href="/Self_profile/blog" class="view-all">View all posts →</a>
		</main>
		<Footer />
	</body>
</html>
